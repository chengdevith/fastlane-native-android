default_platform(:android)

def read_release_notes
  release_notes_path = ENV["RELEASE_NOTES_PATH"].to_s.strip
  default_notes = "SmartServe Native Android Jenkins build ##{ENV['BUILD_NUMBER'] || 'local'}"

  return default_notes if release_notes_path.empty?
  return File.read(release_notes_path) if File.exist?(release_notes_path)

  default_notes
end

platform :android do
  desc "Build native Android app"
  lane :build_android do
    build_type = (ENV["BUILD_TYPE"] || "DEBUG").upcase
    artifact_type = (ENV["ANDROID_ARTIFACT"] || "APK").upcase

    version_name = ENV["VERSION_NAME"] || "1.0.0"
    version_code = ENV["VERSION_CODE"] || ENV["BUILD_NUMBER"] || "1"

    UI.user_error!("VERSION_CODE must be numeric") unless version_code.match?(/^\d+$/)

    gradle_properties = {
      "VERSION_NAME" => version_name,
      "VERSION_CODE" => version_code
    }

    UI.message("Build type: #{build_type}")
    UI.message("Artifact type: #{artifact_type}")
    UI.message("Version name: #{version_name}")
    UI.message("Version code: #{version_code}")

    if build_type == "DEBUG"
      UI.user_error!("DEBUG only supports APK") if artifact_type == "AAB"

      gradle(
        task: "clean assembleDebug",
        properties: gradle_properties
      )
    else
      if artifact_type == "AAB"
        gradle(
          task: "clean bundleRelease",
          properties: gradle_properties
        )
      else
        gradle(
          task: "clean assembleRelease",
          properties: gradle_properties
        )
      end
    end
  end

  desc "Build native Android APK and upload to Firebase"
  lane :firebase_release do
    ENV["BUILD_TYPE"] = "RELEASE"
    ENV["ANDROID_ARTIFACT"] = "APK"

    build_android

    apk_path = Actions.lane_context[SharedValues::GRADLE_APK_OUTPUT_PATH]

    if apk_path.nil? || !File.exist?(apk_path)
      apk_paths = Actions.lane_context[SharedValues::GRADLE_ALL_APK_OUTPUT_PATHS] || []
      apk_path = apk_paths.find { |path| File.exist?(path) }
    end

    UI.message("APK path from Gradle: #{apk_path}")
    UI.user_error!("Release APK not found") if apk_path.nil? || !File.exist?(apk_path)

    firebase_app_id = ENV["FIREBASE_NATIVE_ANDROID_APP_ID"] || ENV["FIREBASE_ANDROID_APP_ID"]
    UI.user_error!("Firebase Android App ID is missing") if firebase_app_id.to_s.strip.empty?
    UI.user_error!("Firebase token is missing") if ENV["FIREBASE_TOKEN"].to_s.strip.empty?

    firebase_app_distribution(
      app: firebase_app_id,
      firebase_cli_token: ENV["FIREBASE_TOKEN"],
      android_artifact_type: "APK",
      android_artifact_path: apk_path,
      groups: "testers",
      release_notes: read_release_notes
    )
  end
end